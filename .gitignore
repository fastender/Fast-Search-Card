# Ignore everything
*

# Except dist folder
!dist/
!dist/index.html
!dist/assets/
!dist/assets/**

# Except HACS files (required for HACS integration)
!hacs.json
!README.md
!info.md
!.gitignore

# Except docs folder
!docs/
!docs/**

# Except scripts folder (dev tooling, committed)
!scripts/
!scripts/**

# Ignore node_modules even in dist
dist/node_modules/
