# Ignore everything
*

# Except dist folder — only the bundled wrapper file is the shipped artifact.
# dist/index.html and dist/assets/* are vite-intermediate outputs (consumed by
# build.sh's inject-css step) — those change every build and shouldn't be in
# version control.
!dist/
!dist/fast-search-card.js

# Except HACS files (required for HACS integration)
!hacs.json
!README.md
!info.md
!.gitignore

# Except docs folder
!docs/
!docs/**

# Except scripts folder (dev tooling, committed)
!scripts/
!scripts/**

# Ignore node_modules even in dist
dist/node_modules/

# macOS metadata — always ignored, never useful in git
.DS_Store
**/.DS_Store
